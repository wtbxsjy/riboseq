nextflow_process {

    name "Test Process GENCODE_ORF_MAPPER"
    script "../main.nf"
    process "GENCODE_ORF_MAPPER"

    tag "modules"
    tag "modules_local"
    tag "gencode_orf_mapper"

    test("Should run without failures - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = file("test.fa")
                input[1] = file("test.bed")
                input[2] = file("ensembl_dir")
                input[3] = "test_project"
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("Should produce expected output files - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = file("test.fa")
                input[1] = file("test.bed")
                input[2] = file("ensembl_dir")
                input[3] = "my_study"
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.unified_fasta != null },
                { assert process.out.unified_bed != null },
                { assert process.out.unified_gtf != null },
                { assert process.out.unified_table != null },
                { assert process.out.versions != null }
            )
        }
    }
}
