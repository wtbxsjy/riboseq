nextflow_process {

    name "Test Process PREPARE_ENSEMBL_ANNOTATION"
    script "../main.nf"
    process "DOWNLOAD_ENSEMBL_FILES"

    tag "modules"
    tag "modules_local"
    tag "prepare_ensembl_annotation"

    test("Should download Ensembl files - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = 110
                input[1] = 'GRCh38'
                input[2] = 'homo_sapiens'
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.ensembl_dir != null },
                { assert process.out.versions != null }
            )
        }
    }

    test("Should work with mouse genome - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = 110
                input[1] = 'GRCm39'
                input[2] = 'mus_musculus'
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.ensembl_dir != null }
            )
        }
    }
}

nextflow_process {

    name "Test Process CALCULATE_PSITE_BED"
    script "../main.nf"
    process "CALCULATE_PSITE_BED"

    tag "modules"
    tag "modules_local"
    tag "prepare_ensembl_annotation"

    test("Should calculate P-sites - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = file('Ens110')
                input[1] = 110
                input[2] = 'GRCh38'
                input[3] = 'homo_sapiens'
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.ensembl_dir_complete != null },
                { assert process.out.versions != null }
            )
        }
    }
}
