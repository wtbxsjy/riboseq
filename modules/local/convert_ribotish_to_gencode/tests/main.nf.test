nextflow_process {

    name "Test Process CONVERT_RIBOTISH_TO_GENCODE"
    script "../main.nf"
    process "CONVERT_RIBOTISH_TO_GENCODE"

    tag "modules"
    tag "modules_local"
    tag "convert_ribotish_to_gencode"

    test("Should convert Ribo-TISH output - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test', study_id:'test_study' ],
                    file('ribotish_predict.txt'),
                    file('ribotish_quality.txt')
                ]
                input[1] = file('genome.fa')
                input[2] = file('annotation.gtf')
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.fasta != null },
                { assert process.out.bed != null },
                { assert process.out.versions != null }
            )
        }
    }

    test("Should handle meta correctly - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'sample1', study_id:'my_study', other:'data' ],
                    file('predict.txt'),
                    file('quality.txt')
                ]
                input[1] = file('genome.fa')
                input[2] = file('annotation.gtf')
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.fasta[0][0].id == 'sample1' },
                { assert process.out.fasta[0][0].study_id == 'my_study' }
            )
        }
    }
}
