Bootstrap: docker
From: rocker/r-ver:4.5.3

%post
    # Install system dependencies
    apt-get update -qq && apt-get install -y -qq \
        libcurl4-openssl-dev \
        libssl-dev \
        libxml2-dev \
        libharfbuzz-dev \
        libfribidi-dev \
        libfreetype6-dev \
        libpng-dev \
        libtiff5-dev \
        libjpeg-dev \
        libgit2-dev \
        libfontconfig1-dev \
        zlib1g-dev \
        libbz2-dev \
        liblzma-dev \
        libgsl-dev \
        cmake \
        && rm -rf /var/lib/apt/lists/*

    # R 4.5.x → Bioconductor 3.21
    Rscript -e 'install.packages(c("BiocManager", "data.table", "dplyr", "tibble", "readr", "purrr", "ggplot2", "ggrepel", "RColorBrewer"), repos = "https://cloud.r-project.org")'
    Rscript -e 'BiocManager::install(c("DESeq2", "apeglm", "SummarizedExperiment", "ComplexHeatmap"), update = FALSE, ask = FALSE, version = "3.21")'

    # Clean up package cache
    rm -rf /tmp/downloaded_packages /tmp/Rtmp*

%environment
    export R_LIBS_USER=/usr/local/lib/R/site-library

%runscript
    exec Rscript "$@"

%labels
    Author Zhe Ren
    Version 2.0
    Description R 4.5.3 + Bioc 3.21 with DESeq2, apeglm, data.table for TE analysis (deltaTE)
