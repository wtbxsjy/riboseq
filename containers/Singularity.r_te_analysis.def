Bootstrap: docker
From: rocker/r-ver:4.5.3

%post
    # ── System dependencies ─────────────────────────────────────────────
    apt-get update -qq && apt-get install -y -qq \
        libcurl4-openssl-dev \
        libssl-dev \
        libxml2-dev \
        libharfbuzz-dev \
        libfribidi-dev \
        libfreetype6-dev \
        libpng-dev \
        libtiff5-dev \
        libjpeg-dev \
        libgit2-dev \
        libfontconfig1-dev \
        zlib1g-dev \
        libbz2-dev \
        liblzma-dev \
        libgsl-dev \
        cmake \
        && rm -rf /var/lib/apt/lists/*

    # ── CRAN packages ───────────────────────────────────────────────────
    Rscript -e 'install.packages(c("BiocManager", "data.table", "dplyr", "tibble",
        "readr", "purrr", "ggplot2", "ggrepel", "RColorBrewer", "Rcpp", "optparse"),
        repos = "https://cloud.r-project.org")'

    # ── Bioconductor packages (TE analysis) ─────────────────────────────
    Rscript -e 'BiocManager::install(c("DESeq2", "apeglm", "SummarizedExperiment",
        "ComplexHeatmap"), update = FALSE, ask = FALSE)'

    # ── Bioconductor packages (annotation — shared with ggRibo) ─────────
    Rscript -e 'BiocManager::install(c(
        "GenomicFeatures", "GenomicAlignments", "Rsamtools",
        "rtracklayer", "AnnotationDbi",
        "txdbmaker", "S4Vectors", "IRanges", "GenomicRanges",
        "Biostrings", "GenomeInfoDb", "XVector"
    ), update = FALSE, ask = FALSE)'

    # ── ggRibo (manual install — source not publicly available) ─────────
    # Install from your local source or private repo:
    #   R CMD INSTALL /path/to/ggRibo
    # Or if available as a tarball:
    #   Rscript -e 'install.packages("/path/to/ggRibo.tar.gz", repos=NULL)'

    # ── Clean cache ─────────────────────────────────────────────────────
    rm -rf /tmp/downloaded_packages /tmp/Rtmp*

%environment
    export R_LIBS_USER=/usr/local/lib/R/site-library

%runscript
    exec Rscript "$@"

%labels
    Author Zhe Ren
    Version 3.1
    Description R 4.5.3 + Bioconductor with DESeq2, apeglm, ComplexHeatmap, GenomicFeatures.
                 For TE analysis (deltaTE). ggRibo can be added manually post-build.
