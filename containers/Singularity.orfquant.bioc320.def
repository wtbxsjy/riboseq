Bootstrap: localimage
From: /home/25119231r/riboseq/run/rice/containers/bioc_3_20.sif

%post
    # Install ALL ORFquant dev branch + RiboseQC dependencies
    R --vanilla -q -e '
        # CRAN packages first
        install.packages(c("rmarkdown","knitr","reshape2","ggplot2","cowplot",
            "gridExtra","dplyr","tidyr","devtools","remotes","optparse","testthat",
            "DT","ggpubr","viridis"),
            repos="https://cloud.r-project.org")
        # BioC packages
        BiocManager::install(c("rtracklayer","BSgenome","Biostrings",
            "GenomicFeatures","multitaper","GenomicAlignments","GenomicFiles",
            "BiocGenerics","Rsamtools","GenomicRanges","BiocParallel",
            "AnnotationDbi","txdbmaker"), update=FALSE, ask=FALSE)
        # RiboseQC (from local source with Bioc 3.20 disjointExons fix)
        pkg_dir <- "/opt/riboseqc/RiboseQC"
        system(sprintf("R CMD INSTALL %s", shQuote(pkg_dir)))
    '

    # Install patched ORFquant (dev branch with exonicParts fix)
    R --vanilla -q -e '
        pkg_dir <- "/opt/ORFquant"
        cmd <- sprintf("R CMD INSTALL %s", shQuote(pkg_dir))
        system(cmd)
        library(ORFquant)
        cat("ORFquant:", as.character(packageVersion("ORFquant")), "\n")
    '

%setup
    ROOTFS="${SINGULARITY_ROOTFS:-${APPTAINER_ROOTFS}}"
    mkdir -p "${ROOTFS}/opt/ORFquant" "${ROOTFS}/opt/riboseqc"

%files
    /home/25119231r/riboseq/ORFquant /opt/ORFquant
    /home/25119231r/riboseq/RiboseQC /opt/riboseqc

%runscript
    exec "$@"

%help
    ORFquant (dev branch, Bioc 3.20) + RiboseQC + txdbmaker
    R 4.4.2, disjointExons→exonicParts fix applied
