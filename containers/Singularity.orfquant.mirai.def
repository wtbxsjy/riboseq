Bootstrap: localimage
From: /media/home/renzhe/projects/Lishuqi/containers/orfquant_patched.sif

%labels
    Author nf-core/riboseq
    Description ORFquant with mirai parallel backend.  Extends orfquant_patched.sif
               by adding mirai + mori + nanonext and the updated ORFquant package.
    Version 1.3.2-mirai

%post
    # Install mirai + mori (nanonext comes as a dependency)
    R --vanilla -q -e '
      install.packages(c("mirai", "mori"), repos = "https://cloud.r-project.org")
      cat("mirai:",  as.character(packageVersion("mirai")),  "\n")
      cat("mori:",   as.character(packageVersion("mori")),   "\n")
      cat("nanonext:", as.character(packageVersion("nanonext")), "\n")
    '

    # Install patched ORFquant (dev branch with mirai support) from local source
    cat > /tmp/install_orfquant.R <<'RSCRIPT'
pkg_dir <- "/opt/orfquant_patched/ORFquant-1.1"
if (!dir.exists(pkg_dir)) stop("Patched ORFquant source not found at: ", pkg_dir)
message("Installing patched ORFquant with mirai support from: ", pkg_dir)
cmd <- sprintf("R CMD INSTALL %s", shQuote(pkg_dir))
message(cmd)
status <- system(cmd)
if (status != 0) stop("R CMD INSTALL failed with status ", status)
library(ORFquant)
message("ORFquant version: ", packageVersion("ORFquant"))
message("mirai available: ", requireNamespace("mirai", quietly=TRUE))
message("mori available: ", requireNamespace("mori", quietly=TRUE))
message("Installation successful!")
RSCRIPT
    R --vanilla -q -f /tmp/install_orfquant.R

%setup
    ROOTFS="${SINGULARITY_ROOTFS:-${APPTAINER_ROOTFS}}"
    mkdir -p "${ROOTFS}/etc" "${ROOTFS}/opt/orfquant_patched"
    rm -f "${ROOTFS}/etc/resolv.conf"
    : > "${ROOTFS}/etc/resolv.conf"
    # Remove old ORFquant source and copy updated version with mirai support
    rm -rf "${ROOTFS}/opt/orfquant_patched/ORFquant-1.1"
    cp -r /localhdd/home/renzhe/riboseq/riboseq/patched_packages/ORFquant-1.1 "${ROOTFS}/opt/orfquant_patched/ORFquant-1.1"
    echo "=== Copied ORFquant source ==="
    ls -la "${ROOTFS}/opt/orfquant_patched/ORFquant-1.1/R/"

%runscript
    exec "$@"

%help
    Extended ORFquant container with mirai parallel backend support.
    Built on top of orfquant_patched.sif (R 4.4.2, Bioconductor 3.20).

    Adds:
    - mirai  (NNG/nanonext async daemon framework)
    - mori   (shared memory for read-only objects)
    - nanonext (NNG transport layer)
    - Updated ORFquant with parallel_backend="mirai" support
