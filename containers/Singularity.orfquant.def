Bootstrap: docker
From: quay.io/biocontainers/riboseqc:1.1--r36_1

%labels
    Author nf-core/riboseq
    Description RiboseQC container with ORFquant pre-installed

%setup
    # Apptainer/Singularity may try to mount a resolv.conf into the container.
    # Some minimal base images don't ship /etc/resolv.conf, which makes the mount fail.
    ROOTFS="${SINGULARITY_ROOTFS:-${APPTAINER_ROOTFS}}"
    mkdir -p "${ROOTFS}/etc"
    # riboseqc base image links /etc/resolv.conf -> /tmp/resolv.conf, but /tmp is
    # typically overmounted at runtime; replace the symlink with a real file so
    # the resolv.conf bind-mount has a stable destination.
    rm -f "${ROOTFS}/etc/resolv.conf"
    : > "${ROOTFS}/etc/resolv.conf"

%post
    # Install ORFquant
    # NOTE: The riboseqc base image ships a BusyBox tar that cannot extract .tar.gz,
    # which breaks remotes::install_* (it shells out to tar). We therefore use
    # R's internal tar/unzip support + R CMD INSTALL.
    #
    # Prefer an offline tarball if one is provided at build time via bind-mount:
    #   apptainer build -B /path/ORFquant.tar.gz:/opt/ORFquant.tar.gz image.sif Singularity.orfquant.def
    # Fallback: download the v1.1 zip from GitHub and unzip with R.

        cat > /tmp/install_orfquant.R <<'RSCRIPT'
tag <- "v1.1"
work <- "/tmp/orfquant_src"
dir.create(work, showWarnings = FALSE, recursive = TRUE)

local_tgz <- "/opt/ORFquant.tar.gz"
if (file.exists(local_tgz) && file.info(local_tgz)$size > 0) {
    utils::untar(local_tgz, exdir = work, tar = "internal")
} else {
    zip_url  <- sprintf("https://github.com/ohlerlab/ORFquant/archive/refs/tags/%s.zip", tag)
    zip_path <- file.path(work, sprintf("ORFquant-%s.zip", tag))
    utils::download.file(zip_url, zip_path, mode = "wb", quiet = FALSE)
    utils::unzip(zip_path, exdir = work)
}

pkg_dir <- list.dirs(work, recursive = FALSE, full.names = TRUE)
if (length(pkg_dir) != 1) {
    stop("Unexpected ORFquant source layout in: ", work)
}

cmd <- sprintf("R CMD INSTALL %s", shQuote(pkg_dir[[1]]))
message(cmd)
status <- system(cmd)
if (status != 0) stop("R CMD INSTALL failed with status ", status)
RSCRIPT

        R --vanilla -q -f /tmp/install_orfquant.R

%runscript
    exec "$@"

%help
    This container includes RiboseQC and ORFquant for Ribo-seq analysis.
    ORFquant is pre-installed so no network access is required at runtime.

    Build with:
        singularity build riboseqc_orfquant.sif Singularity.orfquant.def

    Usage:
        singularity exec riboseqc_orfquant.sif Rscript your_script.R
