/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config for local server with Singularity
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Target hardware: up to 32 CPUs, 64 GB RAM
    Run example: nextflow run . -profile local_singularity --outdir results
----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Local server (Singularity)'
    config_profile_description = 'Local execution using Singularity containers, capped at 32 CPU / 64 GB RAM'

    // Global resource ceilings used by nf-core pipelines
    max_cpus   = 32
    max_memory = '64.GB'
    max_time   = '72.h'
}

// Enable Singularity; disable other engines
singularity {
    enabled = true
    autoMounts = true
}

docker.enabled       = false
podman.enabled       = false
shifter.enabled      = false
charliecloud.enabled = false
apptainer.enabled    = false
conda.enabled        = false

// Allow overwriting reports for repeated local runs
report.overwrite   = true
timeline.overwrite = true
trace.overwrite    = true
dag.overwrite      = true

process {
    // Sensible defaults that scale with retries but stay under host limits
    cpus   = { Math.min(4 * task.attempt, 32) }
    memory = { [8.GB * task.attempt, 64.GB].min() }
    time   = { 8.h * task.attempt }

    // Resource limits act as a hard cap when module labels request more
    resourceLimits = [
        cpus  : 32,
        memory: '64.GB'
    ]

    // Common labels tuned for this machine
    withLabel:process_single {
        cpus   = 1
        memory = 4.GB
        time   = 4.h
    }
    withLabel:process_low {
        cpus   = 4
        memory = 8.GB
        time   = 6.h
    }
    withLabel:process_medium {
        cpus   = 8
        memory = 16.GB
        time   = 12.h
    }
    withLabel:process_high {
        cpus   = 16
        memory = 32.GB
        time   = 24.h
    }
    withLabel:process_high_memory {
        cpus   = 24
        memory = 48.GB
        time   = 36.h
    }
    withLabel:process_long {
        time = 48.h
    }

    // Keep retry strategy consistent with base
    errorStrategy = { task.exitStatus in ((130..145) + 104) ? 'retry' : 'finish' }
    maxRetries    = 2
    maxErrors     = '-1'
}
