/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for Google Colab Pro environment
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Hardware: 8 CPU, 50GB RAM
    Strategy:
      - Use STAR aligner (gold standard for Ribo-seq, requires ~30GB RAM)
      - RPBP with --chains 2 for parallel MCMC (faster, more robust)
      - Full pipeline with all ORF prediction tools

    Usage:
        nextflow run . -profile test_colab,singularity --outdir <OUTDIR>
----------------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus: 8,
        memory: '48.GB',
        time: '4.h'
    ]

    withLabel:process_single {
        cpus   = 1
        memory = '4.GB'
    }
    withLabel:process_low {
        cpus   = 2
        memory = '8.GB'
    }
    withLabel:process_medium {
        cpus   = 4
        memory = '16.GB'
    }
    withLabel:process_high {
        cpus   = 8
        memory = '40.GB'
    }
    withLabel:process_high_memory {
        cpus   = 8
        memory = '48.GB'
    }

    // STAR requires significant memory for genome indexing
    withName: 'STAR_GENOMEGENERATE' {
        cpus   = 8
        memory = '40.GB'
        ext.args = '--genomeSAindexNbases 10'
    }

    withName: 'RPBP_PREPARE_GENOME' {
        cpus   = 8
        memory = '40.GB'
        ext.args = '--star-options "--genomeSAindexNbases 10"'
    }
}

params {
    config_profile_name        = 'Colab Pro Test Profile'
    config_profile_description = 'Test profile for Google Colab Pro (8 CPU, 50GB RAM)'

    // Input data (minimal test dataset)
    input             = 'https://raw.githubusercontent.com/nf-core/test-datasets/riboseq/samplesheet/samplesheet.csv'
    contrasts         = 'https://raw.githubusercontent.com/nf-core/test-datasets/riboseq/contrasts.csv'
    fasta             = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/homo_sapiens/riboseq_expression/Homo_sapiens.GRCh38.dna.chromosome.20.fa.gz'
    gtf               = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/homo_sapiens/riboseq_expression/Homo_sapiens.GRCh38.111_chr20.gtf'
    // Use genome fasta as dummy contaminant (required by RPBP even when filtering is skipped)
    contaminant_fasta = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/homo_sapiens/riboseq_expression/Homo_sapiens.GRCh38.dna.chromosome.20.fa.gz'
    min_trimmed_reads = 1000

    // Aligner: STAR for best quality
    aligner = 'star'

    // Skip contaminant filter (no separate contaminant fasta in test data)
    skip_contaminant_filter = true
    skip_ribotricer         = true

    // RPBP: dual chains for robust MCMC sampling
    extra_rpbp_args = '--chains 2'

    // RiboCode: relax periodicity threshold for small test data
    skip_ribocode       = false
    extra_ribocode_args = '-f0_percent 0.0'

    // Linting
    extra_fqlint_args = '--disable-validator P001 --disable-validator S007'
}
