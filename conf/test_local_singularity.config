/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running locally with Singularity
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Adapted from test_local_conda.config for local execution
    Uses Singularity containers instead of Conda

    Hardware config: Adapted for ~32GB available RAM, 32 CPUs
    Run command: nextflow run . -profile test_local_singularity --outdir results_local_singularity
----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Local Test with Singularity'
    config_profile_description = 'Test profile for local execution using Singularity containers'

    // Resource limits adapted for local machine
    max_cpus   = 32
    max_memory = '64.GB'
    max_time   = '48.h'

    // Input data - override with command line
    input  = null

    // Reference genome - override with command line
    fasta              = null
    gtf                = null
    contaminant_fasta  = null
    transcript_fasta   = null

    // Use STAR aligner (default)
    aligner = 'star'

    // ORF prediction tools
    skip_ribotish   = false
    skip_ribotricer = false
    skip_ribocode   = false
    skip_rpbp       = false

    // RPBP settings
    extra_rpbp_args = '--chains 2'

    // RiboseQC
    skip_riboseqc = false
    
    // Skip linting due to validator issues
    skip_linting = true
}

// Enable report overwriting
report.overwrite = true
timeline.overwrite = true
trace.overwrite = true
dag.overwrite = true

// Singularity configuration
singularity {
    enabled     = true
    autoMounts  = true
    cacheDir    = "${HOME}/.singularity/cache"
    pullTimeout = '2h'  // Increase timeout for large images
    // Mount host resolv.conf to fix DNS resolution in container
    runOptions  = '-B /etc/resolv.conf:/etc/resolv.conf:ro'
}

// Disable other container engines
conda.enabled        = false
docker.enabled       = false
podman.enabled       = false
shifter.enabled      = false
charliecloud.enabled = false
apptainer.enabled    = false

// Process resource configuration
process {
    // Default resources
    cpus   = { 2 * task.attempt }
    memory = { 8.GB * task.attempt }
    time   = { 4.h * task.attempt }

    // STAR alignment needs more memory
    withName: 'STAR_GENOMEGENERATE' {
        cpus   = 8
        memory = { 32.GB * task.attempt }
    }

    withName: 'STAR_ALIGN' {
        cpus   = 8
        memory = { 24.GB * task.attempt }
    }

    // RPBP resources
    withName: 'RPBP.*' {
        cpus   = 4
        memory = { 16.GB * task.attempt }
    }

    withName: 'RIBOTRICER_DETECTORFS' {
        errorStrategy = 'ignore'
    }

    // Cap resources for high-memory processes
    withLabel:process_high {
        cpus   = 16
        memory = { 48.GB * task.attempt > 64.GB ? 64.GB : 48.GB * task.attempt }
    }
    withLabel:process_medium {
        cpus   = 8
        memory = { 32.GB * task.attempt > 64.GB ? 64.GB : 32.GB * task.attempt }
    }
    withLabel:process_high_memory {
        memory = { 64.GB * task.attempt > 64.GB ? 64.GB : 64.GB * task.attempt }
    }
}

process {
    withName: '.*:ORFQUANT:ORFQUANT_RUN' {
        errorStrategy = 'ignore'
    }
}
