/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running locally with Singularity
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Adapted from test_local_conda.config for local execution
    Uses Singularity containers instead of Conda

    Hardware config: Adapted for ~180GB available RAM, 50 CPUs
    Run command: nextflow run . -profile test_local_singularity --outdir results_local_singularity
----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Local Test with Singularity'
    config_profile_description = 'Test profile for local execution using Singularity containers'

    // Resource limits adapted for local machine
    max_cpus   = 50
    max_memory = '180.GB'
    max_time   = '48.h'

    // Input data - override with command line
    input  = null

    // Reference genome - override with command line
    fasta              = null
    gtf                = null
    contaminant_fasta  = null
    transcript_fasta   = null

    // Use STAR aligner (default)
    aligner = 'star'

    // ORF prediction tools
    skip_ribotish   = false
    skip_ribotricer = false
    skip_ribocode   = false
    skip_rpbp       = false

    // RPBP settings
    extra_rpbp_args = '--chains 2'

    // RPBP custom container (local .sif)
    // Copy your downloaded image to this path on the machine where you run Nextflow,
    // or override at runtime with: --rpbp_container /abs/path/rpbp.sif
    rpbp_container = "${baseDir}/rpbp.sif"

    // RiboseQC
    skip_riboseqc = false

    // Custom ORFquant container (recommended for VMs with DNS/network issues)
    // Copy your built SIF to: $projectDir/containers/orfquant.sif
    orfquant_container = "${projectDir}/containers/orfquant.sif"
    
    // Skip linting due to validator issues
    skip_linting = true
}

// Enable report overwriting
report.overwrite = true
timeline.overwrite = true
trace.overwrite = true
dag.overwrite = true

// Singularity configuration
singularity {
    enabled     = true
    autoMounts  = true
    cacheDir    = "${HOME}/.singularity/cache"
    pullTimeout = '2h'  // Increase timeout for large images
    // Singularity uses host network by default, no special options needed
    // If DNS issues persist, check VM's /etc/resolv.conf on the host
}

// Disable other container engines
conda.enabled        = false
docker.enabled       = false
podman.enabled       = false
shifter.enabled      = false
charliecloud.enabled = false
apptainer.enabled    = false

// Process resource configuration
process {
    // Default resources
    cpus   = { 4 * task.attempt }
    memory = { 16.GB * task.attempt }
    time   = { 6.h * task.attempt }

    // STAR alignment needs more memory
    withName: 'STAR_GENOMEGENERATE' {
        cpus   = 16
        memory = { 96.GB * task.attempt }
    }

    withName: 'STAR_ALIGN' {
        cpus   = 16
        memory = { 72.GB * task.attempt }
    }

    // RPBP resources
    withName: 'RPBP.*' {
        cpus   = 8
        memory = { 32.GB * task.attempt }
    }

    // RPBP metagene/profile steps can spike memory and trigger heavy swap/IO (process stuck in D state).
    // This is a per-process cap to keep the request bounded; on schedulers it also helps enforce limits.
    // If you still hit D-state, consider also reducing parallelism (e.g. maxForks = 1) or lowering --max_memory.
    withName: 'RPBP_PREDICT' {
        cpus   = 12
        memory = 16.GB
        time   = 24.h
    }

    withName: 'RIBOTRICER_DETECTORFS' {
        errorStrategy = 'ignore'
    }

    // Cap resources for high-memory processes
    withLabel:process_high {
        cpus   = 32
        memory = { 128.GB * task.attempt > 180.GB ? 180.GB : 128.GB * task.attempt }
    }
    withLabel:process_medium {
        cpus   = 16
        memory = { 64.GB * task.attempt > 180.GB ? 180.GB : 64.GB * task.attempt }
    }
    withLabel:process_high_memory {
        memory = { 180.GB * task.attempt > 180.GB ? 180.GB : 180.GB * task.attempt }
    }
}

process {
    withName: '.*:ORFQUANT:ORFQUANT_RUN' {
        errorStrategy = 'ignore'
        // Allow multiple ORFquant jobs to run in parallel
        // Override with --orfquant_maxForks on command line
        maxForks = params.orfquant_maxForks ?: 6
    }
}
