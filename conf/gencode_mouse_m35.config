/*
 * GENCODE M35 (GRCm39) 小鼠测试配置
 * 用于 nf-core/riboseq 流程
 */

params {
    config_profile_name        = 'GENCODE Mouse M35'
    config_profile_description = 'Configuration for mouse GENCODE M35 (GRCm39, Ensembl 112)'

    // 输入文件
    genome_fasta = '/path/to/GRCm39.primary_assembly.genome.fa'
    gtf          = '/path/to/gencode.vM35.annotation.gtf'

    // GENCODE 特殊处理
    gencode = true  // 重要！启用 GENCODE GTF 特殊处理

    // 物种信息
    species         = 'mus_musculus'
    genome_assembly = 'GRCm39'

    // GENCODE 注释参数
    skip_gencode_annotation     = false
    ensembl_release             = 112  // 对应 GENCODE M35
    project_id                  = 'mouse_project'
    gencode_orf_min_length      = 16
    gencode_min_phase_score     = 0.5
    gencode_collapse_threshold  = 0.9
    gencode_collapse_method     = 'longest_string'

    // 小鼠染色体过滤（排除线粒体和未组装序列）
    sorf_exclude_contigs_regex = '(chrM|chrUn.*|.*_random|JH.*|GL.*)'

    // ORF 预测工具
    skip_ribotish   = false
    skip_ribotricer = false
    skip_ribocode   = true   // 可选
    skip_rpbp       = true   // 可选
}

// 资源配置（根据你的服务器调整）
process {
    withName: 'CONVERT_RIBOTISH_TO_GENCODE' {
        cpus   = 1
        memory = 4.GB
        time   = 1.h
    }

    withName: 'CONVERT_RIBOTRICER_TO_GENCODE' {
        cpus   = 1
        memory = 4.GB
        time   = 1.h
    }

    withName: 'GENCODE_ORF_MAPPER' {
        cpus   = 1
        memory = 8.GB
        time   = 4.h
    }
}
