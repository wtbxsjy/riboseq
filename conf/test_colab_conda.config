/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running on Google Colab with Conda
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    适用于 Google Colab Pro 高内存节点
    使用 Conda 替代 Docker/Singularity (Colab 不支持容器化)

    硬件配置: 8 CPU, ~50GB RAM
    运行方式: nextflow run . -profile test_colab_conda --outdir results_colab
----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Google Colab Pro with Conda'
    config_profile_description = 'Test profile for Google Colab Pro using Conda environment'

    // 限制资源以适应 Colab Pro 高内存节点
    max_cpus   = 8
    max_memory = '48.GB'
    max_time   = '24.h'

    // 输入数据
    input  = 'https://raw.githubusercontent.com/nf-core/test-datasets/riboseq/samplesheet/samplesheet.csv'

    // 参考基因组 (使用小型测试数据集)
    fasta              = 'https://raw.githubusercontent.com/nf-core/test-datasets/riboseq/reference/chrM.fa'
    gtf                = 'https://raw.githubusercontent.com/nf-core/test-datasets/riboseq/reference/chrM.gtf'
    transcript_fasta   = 'https://raw.githubusercontent.com/nf-core/test-datasets/riboseq/reference/chrM_transcripts.fa'

    // 使用 STAR 比对器 (Ribo-seq 黄金标准)
    aligner = 'star'

    // ORF 预测工具 (使用 skip_xxx = false 表示启用)
    // 项目支持 4 个 ORF 预测工具: Ribotish, Ribotricer, RiboCode, RPBP
    skip_ribotish   = false   // 启用 Ribotish
    skip_ribotricer = false   // 启用 Ribotricer
    skip_ribocode   = false   // 启用 RiboCode
    skip_rpbp       = false   // 启用 RPBP

    // RPBP 双链模式提高准确性
    extra_rpbp_args = '--chains 2'

    // RiboseQC: 已支持 Conda，可以启用
    skip_riboseqc = false
}

// Conda 配置
conda {
    enabled = true
    useMamba = true  // 使用 Mamba 加速依赖解析
}

// 禁用所有容器化选项
docker.enabled       = false
singularity.enabled  = false
podman.enabled       = false
shifter.enabled      = false
charliecloud.enabled = false
apptainer.enabled    = false

// 进程资源配置
process {
    // 降低默认资源以适应 Colab
    cpus   = { check_max( 2 * task.attempt, 'cpus' ) }
    memory = { check_max( 8.GB * task.attempt, 'memory' ) }
    time   = { check_max( 4.h * task.attempt, 'time' ) }

    // STAR 比对需要更多内存
    withName: 'STAR_GENOMEGENERATE' {
        cpus   = { check_max( 4, 'cpus' ) }
        memory = { check_max( 32.GB * task.attempt, 'memory' ) }
    }

    withName: 'STAR_ALIGN' {
        cpus   = { check_max( 4, 'cpus' ) }
        memory = { check_max( 24.GB * task.attempt, 'memory' ) }
    }

    // RPBP 需要更多资源
    withName: 'RPBP.*' {
        cpus   = { check_max( 4, 'cpus' ) }
        memory = { check_max( 16.GB * task.attempt, 'memory' ) }
    }
}
