/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running on Google Colab with Conda/Mamba
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    使用 Conda/Mamba 替代 Docker/Singularity (Colab 通常不支持 Apptainer/Singularity overlay)

    运行方式: nextflow run . -profile test_colab_conda --outdir results_colab
----------------------------------------------------------------------------------------
*/

/*
  Helper: cap resources by nf-core style params.max_*.
  Some profiles in this repo use check_max() but the base config does not define it,
  so we define it here to keep Colab profiles self-contained.
*/
def check_max(obj, type) {
    def max = params["max_${type}"]
    if (max == null) return obj
    try {
        return obj > max ? max : obj
    } catch (Exception ignored) {
        // If types are not directly comparable, return the requested value.
        return obj
    }
}

params {
    config_profile_name        = 'Google Colab Pro with Conda'
    config_profile_description = 'Test profile for Google Colab using Conda/Mamba (no containers)'

    // 资源上限（可在命令行用 --max_cpus/--max_memory/--max_time 覆盖）
    // 默认值对齐 test_local_singularity，便于从 singularity 迁移到 conda/mamba
    max_cpus   = 16
    max_memory = '56.GB'
    max_time   = '48.h'

    // 输入/参考（建议在命令行指定；这里默认不绑定特定测试数据集）
    input            = null
    fasta            = null
    gtf              = null
    contaminant_fasta = null
    transcript_fasta = null

    // 使用 STAR 比对器 (Ribo-seq 黄金标准)
    aligner = 'star'

    // ORF 预测工具 (使用 skip_xxx = false 表示启用)
    // 项目支持 4 个 ORF 预测工具: Ribotish, Ribotricer, RiboCode, RPBP
    skip_ribotish   = false   // 启用 Ribotish
    skip_ribotricer = false   // 启用 Ribotricer
    skip_ribocode   = false   // 启用 RiboCode
    skip_rpbp       = false   // 启用 RPBP

    // RPBP 双链模式提高准确性
    extra_rpbp_args = '--chains 2'

    // RiboseQC: 已支持 Conda，可以启用
    skip_riboseqc = false

    // Skip linting due to validator issues
    skip_linting = true
}

// Conda 配置
conda {
    enabled = true
    useMamba = true  // 使用 Mamba 加速依赖解析
}

// 禁用所有容器化选项
docker.enabled       = false
singularity.enabled  = false
podman.enabled       = false
shifter.enabled      = false
charliecloud.enabled = false
apptainer.enabled    = false

// 进程资源配置
process {
    // 默认资源（使用 check_max 避免超过 params.max_*）
    cpus   = { check_max( 2 * task.attempt, 'cpus' ) }
    memory = { check_max( 8.GB * task.attempt, 'memory' ) }
    time   = { check_max( 4.h * task.attempt, 'time' ) }

    // STAR 比对需要更多内存
    withName: 'STAR_GENOMEGENERATE' {
        cpus   = { check_max( 4, 'cpus' ) }
        memory = { check_max( 32.GB * task.attempt, 'memory' ) }
    }

    withName: 'STAR_ALIGN' {
        cpus   = { check_max( 4, 'cpus' ) }
        memory = { check_max( 24.GB * task.attempt, 'memory' ) }
    }

    // RPBP 需要更多资源
    withName: 'RPBP.*' {
        cpus   = { check_max( 4, 'cpus' ) }
        memory = { check_max( 16.GB * task.attempt, 'memory' ) }
    }

    withName: 'RIBOTRICER_DETECTORFS' {
        errorStrategy = 'ignore'
    }

    // 资源 cap（与 test_local_singularity 思路一致，且遵守 max_*）
    withLabel:process_high {
        cpus   = { check_max( 16, 'cpus' ) }
        memory = { check_max( 48.GB * task.attempt, 'memory' ) }
    }
    withLabel:process_medium {
        cpus   = { check_max( 8, 'cpus' ) }
        memory = { check_max( 32.GB * task.attempt, 'memory' ) }
    }
    withLabel:process_high_memory {
        memory = { check_max( 56.GB * task.attempt, 'memory' ) }
    }
}

process {
    withName: '.*:ORFQUANT:ORFQUANT_RUN' {
        errorStrategy = 'ignore'
    }
}
