/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running locally with Conda
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Adapted from test_colab_conda.config for local execution
    Uses Conda instead of Docker/Singularity

    Hardware config: Adapted for ~16GB available RAM, 16 CPUs
    Run command: nextflow run . -profile test_local_conda --outdir results_local_conda
----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Local Test with Conda'
    config_profile_description = 'Test profile for local execution using Conda environment'

    // Resource limits adapted for local machine (31GB total, ~17GB available)
    max_cpus   = 12
    max_memory = '32.GB'  // Leave some buffer
    max_time   = '24.h'

    // Input data
    input  = '/mnt/d/data/FYP_data/nextflow/test_data/samplesheet.csv'

    // Reference genome (small test dataset)
    fasta              = '/mnt/d/data/FYP_data/nextflow/test_data/Homo_sapiens.GRCh38.dna.chromosome.20.fa.gz'
    gtf                = '/mnt/d/data/FYP_data/nextflow/test_data/Homo_sapiens.GRCh38.111_chr20.gtf'
    contaminant_fasta  = null  // Override with --contaminant_fasta on command line
    transcript_fasta   = null // Will be generated from genome and GTF if not provided, or we can omit it to force generation

    // Use HISAT2 aligner
    aligner = 'hisat2'
    hisat2_build_memory = '24.GB'

    // ORF prediction tools
    skip_ribotish   = false
    skip_ribotricer = false
    skip_ribocode   = false
    skip_rpbp       = false

    // RPBP settings
    extra_rpbp_args = '--chains 2'

    // RiboseQC
    skip_riboseqc = false
    
    // Skip linting due to validator issues
    skip_linting = true
}

// Enable report overwriting
report.overwrite = true
timeline.overwrite = true
trace.overwrite = true
dag.overwrite = true

// Conda configuration
conda {
    enabled = true
    useMamba = true
}

// Disable container engines
docker.enabled       = false
singularity.enabled  = false
podman.enabled       = false
shifter.enabled      = false
charliecloud.enabled = false
apptainer.enabled    = false

// Process resource configuration
process {
    // Default resources
    cpus   = { 2 * task.attempt }
    memory = { 4.GB * task.attempt }
    time   = { 4.h * task.attempt }

    // STAR alignment needs more memory
    withName: 'STAR_GENOMEGENERATE' {
        cpus   = 4
        memory = { 12.GB * task.attempt }
    }

    withName: 'STAR_ALIGN' {
        cpus   = 4
        memory = { 12.GB * task.attempt }
    }

    // RPBP resources
    withName: 'RPBP.*' {
        cpus   = 4
        memory = { 8.GB * task.attempt }
    }

    // RiboTISH predict can take longer than the default 4h on local machines
    withName: 'RIBOTISH_PREDICT_(ALL|INDIVIDUAL)' {
        time = { 12.h * task.attempt }
    }

    withName: 'RIBOTRICER_DETECTORFS' {
        errorStrategy = 'ignore'
    }

    // Cap resources for high-memory processes
    withLabel:process_high {
        cpus   = 12
        memory = { 32.GB * task.attempt > 32.GB ? 32.GB : 32.GB * task.attempt }
    }
    withLabel:process_medium {
        cpus   = 6
        memory = { 24.GB * task.attempt > 24.GB ? 24.GB : 24.GB * task.attempt }
    }
    withLabel:process_high_memory {
        memory = { 32.GB * task.attempt > 32.GB ? 32.GB : 32.GB * task.attempt }
    }
}

process {
    withName: '.*:ORFQUANT:ORFQUANT_RUN' {
        errorStrategy = 'ignore'
    }
}
