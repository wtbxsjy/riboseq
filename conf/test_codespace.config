/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for GitHub Codespace environment
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Hardware: 2 CPU, 8GB RAM
    Strategy:
      - Use HISAT2 aligner (low memory footprint, ~2GB vs STAR's 30GB+)
      - RPBP with --chains 1 for serial MCMC (reduces peak memory)
      - Reserve 2GB for system, use max 6GB for pipeline

    Usage:
        nextflow run . -profile test_codespace,singularity --outdir <OUTDIR>
----------------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus: 2,
        memory: '6.GB',
        time: '2.h'
    ]

    withLabel:process_single {
        cpus   = 1
        memory = '2.GB'
    }
    withLabel:process_low {
        cpus   = 2
        memory = '4.GB'
    }
    withLabel:process_medium {
        cpus   = 2
        memory = '6.GB'
    }
    withLabel:process_high {
        cpus   = 2
        memory = '6.GB'
    }
    withLabel:process_high_memory {
        cpus   = 2
        memory = '6.GB'
    }
}

params {
    config_profile_name        = 'Codespace Test Profile'
    config_profile_description = 'Test profile for GitHub Codespace (2 CPU, 8GB RAM)'

    // Input data (minimal test dataset)
    input             = 'https://raw.githubusercontent.com/nf-core/test-datasets/riboseq/samplesheet/samplesheet.csv'
    contrasts         = 'https://raw.githubusercontent.com/nf-core/test-datasets/riboseq/contrasts.csv'
    fasta             = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/homo_sapiens/riboseq_expression/Homo_sapiens.GRCh38.dna.chromosome.20.fa.gz'
    gtf               = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/homo_sapiens/riboseq_expression/Homo_sapiens.GRCh38.111_chr20.gtf'
    min_trimmed_reads = 1000

    // Aligner: HISAT2 for low memory usage
    aligner = 'hisat2'

    // Skip memory-intensive or unnecessary steps
    skip_contaminant_filter = true
    skip_ribotricer         = true

    // RPBP: single chain for low memory
    extra_rpbp_args = '--chains 1'

    // RiboCode: relax periodicity threshold for small test data
    skip_ribocode       = false
    extra_ribocode_args = '-f0_percent 0.0'

    // Linting
    extra_fqlint_args = '--disable-validator P001 --disable-validator S007'
}
