{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/nf-core/riboseq/master/assets/schema_input.json",
    "title": "nf-core/riboseq pipeline - params.input schema",
    "description": "Schema for the file provided with params.input",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "sample": {
                "type": "string",
                "pattern": "^\\S+$",
                "errorMessage": "Sample name must be provided and cannot contain spaces",
                "meta": ["id"]
            },
            "fastq_1": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^\\S+\\.f(ast)?q\\.gz$",
                "errorMessage": "FastQ file for reads 1 cannot contain spaces and must have extension '.fq.gz' or '.fastq.gz'"
            },
            "fastq_2": {
                "errorMessage": "FastQ file for reads 2 cannot contain spaces and must have extension '.fq.gz' or '.fastq.gz'",
                "type": "string",
                "format": "file-path",
                "exists": true,
                "anyOf": [
                    {
                        "pattern": "^\\S+\\.f(ast)?q\\.gz$"
                    },
                    {
                        "maxLength": 0
                    }
                ]
            },
            "bam": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^\\S+\\.bam$",
                "errorMessage": "BAM file path cannot contain spaces and must have extension '.bam'"
            },
            "bam_index": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^\\S+\\.(bai|csi)$",
                "errorMessage": "BAM index file path cannot contain spaces and must have extension '.bai' or '.csi'"
            },
            "strandedness": {
                "type": "string",
                "errorMessage": "Strandedness must be provided and be one of 'auto', 'forward', 'reverse' or 'unstranded'",
                "enum": ["forward", "reverse", "unstranded", "auto"],
                "meta": ["strandedness"]
            },
            "type": {
                "type": "string",
                "errorMessage": "Sample type must be provided and be one of 'riboseq', 'rnaseq' or 'tiseq'",
                "enum": ["riboseq", "rnaseq", "tiseq"],
                "meta": ["sample_type"]
            },
            "group": {
                "type": "string",
                "pattern": "^\\S+$",
                "errorMessage": "Group name cannot contain spaces",
                "meta": ["group"]
            }
        },
        "required": ["sample", "strandedness", "type"],
        "oneOf": [
            {
                "required": ["fastq_1"],
                "properties": {
                    "bam": { "maxLength": 0 }
                }
            },
            {
                "required": ["bam"],
                "properties": {
                    "fastq_1": { "maxLength": 0 },
                    "fastq_2": { "maxLength": 0 },
                    "strandedness": {
                        "enum": ["forward", "reverse", "unstranded"],
                        "errorMessage": "When using BAM input, strandedness must be 'forward', 'reverse' or 'unstranded' (not 'auto')"
                    }
                }
            }
        ]
    }
}
